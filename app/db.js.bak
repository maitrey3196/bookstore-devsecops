const sqlite3 = require('sqlite3').verbose();

const db = new sqlite3.Database('./data/bookstore.db');

db.serialize(() => {

  db.run(`
    CREATE TABLE IF NOT EXISTS users (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      username TEXT,
      password TEXT
    )
  `);

  db.run(`
    CREATE TABLE IF NOT EXISTS books (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      title TEXT,
      author TEXT,
      price REAL
    )
  `);

  db.run(`
    CREATE TABLE IF NOT EXISTS orders (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      username TEXT,
      book TEXT
    )
  `);

  db.run(`
    INSERT OR IGNORE INTO books(id,title,author,price)
    VALUES
    (1,'Docker Deep Dive','Nigel Poulton',30),
    (2,'Kubernetes Up & Running','Kelsey Hightower',40),
    (3,'OWASP Testing Guide','OWASP',20),
    (4,'DevSecOps Handbook','Gene Kim',50)
  `);

});

module.exports = db;
